<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="ServerUI" style="flex-grow: 1; background-color: rgba(0, 255, 150, 0.56); position: absolute; height: 216px; width: 300px; top: 12px; left: auto; right: 10px; opacity: 1; visibility: visible;">
        <ui:Button text="Host" name="HostButton"/>
        <ui:Button text="Server" name="ServerButton"/>
        <ui:Button text="Client" name="ClientButton"/>
        <ui:Button text="Disconnect" name="DisconnectButton"/>
        <ui:TextField label="Ip Adress&#10;" placeholder-text="filler text" name="IPAdressTextField" style="-unity-slice-left: 2; -unity-slice-top: 2; -unity-slice-right: 2; -unity-slice-bottom: 2; white-space: normal; justify-content: flex-end; align-items: flex-start; overflow: visible; flex-basis: auto; flex-shrink: 0; flex-grow: 0; flex-wrap: nowrap; flex-direction: row; width: 100%; margin-right: 0; margin-left: 4px; font-size: 8px; text-overflow: clip; align-content: auto; position: relative; right: auto; background-size: 100% 100%; background-position-x: center; background-position-y: center; -unity-background-scale-mode: stretch-to-fill; -unity-text-align: upper-left;"/>
    </ui:VisualElement>
</ui:UXML>
